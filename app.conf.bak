    # web server
    server {
        listen       443 ssl;
        listen       4443 ssl;
        listen       1882 ssl ;
        listen       1884 ssl ;
        server_name app.clouduse01.com;
    ssl_certificate /etc/letsencrypt/live/app.clouduse01.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/app.clouduse01.com/privkey.pem; # managed by Certbot
        #ssl on;
                ssl_session_timeout 5m;
        ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
        ssl_ciphers ECDH:AESGCM:HIGH:!RC4:!DH:!MD5:!aNULL:!eNULL;
        error_page   500 502 503 504  /50x.html;

        location = /50x.html {
                root   html;
        }
        location = /.well-known/acme-challenge/ {
            proxy_pass http://54.88.6.239;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # QV Monitor PWA
        location /monitor/ {
            alias /usr/local/nginx/html/qv-monitor/;
            index index.html;
            try_files $uri $uri/ /monitor/index.html;
        }

        # Cloud API Proxy
        location /api/cloud/ {
            proxy_pass https://openapi.qvcloud.net/;
            proxy_set_header Host openapi.qvcloud.net;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_ssl_server_name on;
            proxy_ssl_protocols TLSv1.2 TLSv1.3;
        }

        # Device Proxy for CORS
        location ~* ^/api/device-proxy/([^/]+)(/.*)$ {
            set $target_host $1;
            set $remaining_path $2;
            resolver 8.8.8.8;
            proxy_pass https://$target_host$remaining_path;
            proxy_set_header Host $target_host;
            proxy_ssl_verify off;
            add_header "Access-Control-Allow-Origin" "*" always;
        }

        location / {
            root   /usr/local/nginx/html/browser;
            index  index.html;
        }
    }

    server {
        if ($host = web.qvcloud.net) {
            return 301 https://$host$request_uri;
        } # managed by Certbot

        listen       80;
        server_name web.qvcloud.net;
        return 301 https://$host$request_uri;
    }
